source "https://rubygems.org"

# github-pages pins Jekyll + plugin versions to match GitHub Pages production.
# The gems below are declared explicitly for clarity; Bundler resolves compatible versions.
group :jekyll_plugins do
  gem "github-pages"
  gem "jekyll"
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
end
